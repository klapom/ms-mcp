#!/bin/sh
# Pre-push hook: Run security audit and E2E tests before pushing to remote

echo "Pre-push: Running pnpm audit (production dependencies)..."
pnpm audit --prod 2>/dev/null
AUDIT_EXIT=$?

if [ $AUDIT_EXIT -ne 0 ]; then
    echo ""
    echo "WARNING: pnpm audit found vulnerabilities (exit code: $AUDIT_EXIT)."
    echo "   Review with: pnpm audit --prod"
    echo "   This is non-blocking but should be addressed."
    echo ""
fi

echo "Pre-push: Running Phase 8 E2E tests..."
bash ./scripts/preview-hook.sh

if [ $? -ne 0 ]; then
    echo ""
    echo "E2E tests failed. Push cancelled."
    echo "   Run tests manually: ./scripts/preview-hook.sh"
    echo "   or skip with: git push --no-verify"
    exit 1
fi

echo ""
echo "Pre-push checks passed. Proceeding with push..."
exit 0
