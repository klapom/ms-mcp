{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "cat '../agent-personas/CLAUDE.md'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(pnpm run *)",
      "Bash(pnpm *)",
      "Bash(npx vitest *)",
      "Bash(npx biome *)",
      "Bash(npx tsup *)",
      "Bash(npx tsx *)",
      "Bash(node *)",
      "Bash(git *)"
    ],
    "deny": []
  }
}
